AFIP_USERNAME=username
AFIP_PASSWORD=password
AFIP_ISSUER_CUIT=20123456789
RAZON_SOCIAL="PEPITO SRL"
FILE=csv/example.csv
GLOBAL_CONCEPT=
ADD_MONTH_TO_CONCEPT=true

# MCP HTTP file server — base URL (no port) used to build PDF download URLs.
# When set, emit_invoice returns a downloadUrl per issued invoice.
INVOICE_SERVER_HOST=http://localhost

# Port for the embedded HTTP server that serves generated PDFs under /public/invoices/.
INVOICE_HTTP_SERVER_PORT=8876

# Port for the MCP HTTP/SSE transport. Optional: omit to run MCP over stdio only.
INVOICE_MCP_SERVER_PORT=9000

# Secret key for encrypting AFIP passwords in the local SQLite client store.
# Required when using the store_client MCP tool.
CLIENT_STORE_SECRET_KEY=change-me-to-a-strong-random-string
